page {
  --bg: #fafafa;
  --card: #ffffff;
  --text: #262626;
  --text-secondary: #8e8e8e;
  --text-muted: #c7c7c7;
  --border: #efefef;
  --accent: #e1306c;
  --accent-soft: rgba(225, 48, 108, 0.12);
  --gradient: linear-gradient(
    135deg,
    #f9ce34 0%,
    #ee2a7b 50%,
    #6228d7 100%
  );
  --shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  --radius-lg: 28rpx;
  --radius-md: 20rpx;
  --safe-bottom: env(safe-area-inset-bottom);

  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  box-sizing: border-box;
}

.ins-page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(140rpx + var(--safe-bottom));
  box-sizing: border-box;
}

.ins-gradient-text {
  background: var(--gradient);
  -webkit-background-clip: text;
  color: transparent;
}

.ins-card {
  background: var(--card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  border: 1rpx solid var(--border);
}

.ins-btn-primary {
  background: var(--gradient) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 999rpx !important;
  font-weight: 600 !important;
  font-size: 30rpx !important;
  box-shadow: 0 12rpx 28rpx rgba(238, 42, 123, 0.28);
}

.ins-btn-primary::after {
  border: none;
}

.ins-input {
  background: #f5f5f5;
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  height: 96rpx;
  font-size: 28rpx;
  color: var(--text);
}

.ins-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin: 40rpx 0 20rpx;
}
